# =============================================
# DISCORD — configurações globais do bot
# =============================================
DISCORD_TOKEN=seu_token_aqui
CLIENT_ID=id_do_seu_bot

# =============================================
# DATABASE
# =============================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/police_bot

# =============================================
# WHITELIST DE SERVIDORES
# =============================================
# IDs dos servidores autorizados a usar o bot (separados por vírgula)
# O bot sairá automaticamente de qualquer servidor que não esteja aqui
ALLOWED_GUILD_IDS=id_servidor1,id_servidor2

# =============================================
# BOT OWNER
# =============================================
# Seu Discord user ID — único autorizado a usar /atividade
BOT_OWNER_ID=seu_user_id_aqui

# =============================================
# OPTIONAL
# =============================================
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────
# ATENÇÃO: Não existe mais GUILD_ID, SHIFT_CHANNEL_ID,
# REPORT_CHANNEL_ID, WEAPON_REPORT_CHANNEL_ID,
# VOICE_CATEGORY_ID nem SUPERVISOR_ROLE_IDS no .env.
#
# Todas as configurações por servidor são feitas via:
#   /configurar canal-turnos
#   /configurar canal-relatorios
#   /configurar canal-armamento
#   /configurar categoria-voz
#   /configurar cargo-supervisor
#
# E consultadas via /configuracoes
# ─────────────────────────────────────────────
